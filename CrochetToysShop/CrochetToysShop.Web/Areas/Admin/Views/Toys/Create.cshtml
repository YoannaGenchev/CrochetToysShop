@model CrochetToysShop.Web.ViewModels.Toys.ToyFormViewModel

@{
    ViewData["Title"] = "Add toy";
}

<div class="admin-toy-form-page">
    <h2 class="page-title toy-form-title">@ViewData["Title"]</h2>

    <div class="admin-toy-form-shell">
        <form asp-area="Admin" asp-action="Create" method="post" class="toy-form-card admin-toy-form">
            <div class="toy-form-field">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger field-validation-msg"></span>
            </div>

            <div class="toy-form-field">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger field-validation-msg"></span>
            </div>

            <div class="row g-3">
                <div class="col-md-4">
                    <div class="toy-form-field">
                        <label asp-for="Price" class="form-label"></label>
                        <input asp-for="Price" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger field-validation-msg"></span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="toy-form-field">
                        <label asp-for="SizeCm" class="form-label"></label>
                        <input asp-for="SizeCm" class="form-control" />
                        <span asp-validation-for="SizeCm" class="text-danger field-validation-msg"></span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="toy-form-field">
                        <label asp-for="Difficulty" class="form-label"></label>
                        <select asp-for="Difficulty" class="form-select">
                            <option value="Easy">Easy</option>
                            <option value="Medium">Medium</option>
                            <option value="Hard">Hard</option>
                        </select>
                        <span asp-validation-for="Difficulty" class="text-danger field-validation-msg"></span>
                    </div>
                </div>
            </div>

            <div class="toy-form-field">
                <label asp-for="ImageUrl" class="form-label"></label>
                <input asp-for="ImageUrl" class="form-control" />
                <small class="form-text text-muted toy-form-hint">Expected format: /images/toys/example.jpg</small>
                <span asp-validation-for="ImageUrl" class="text-danger field-validation-msg"></span>
            </div>

            <div class="toy-form-field">
                <label asp-for="CategoryId" class="form-label"></label>
                <select asp-for="CategoryId" class="form-select">
                    <option value="0">-- select --</option>
                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
                <span asp-validation-for="CategoryId" class="text-danger field-validation-msg"></span>
            </div>

            <div class="form-check mb-3 toy-form-field">
                <input asp-for="IsAvailable" class="form-check-input" />
                <label asp-for="IsAvailable" class="form-check-label"></label>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-4 toy-form-actions admin-toy-form-actions">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-area="" asp-controller="Toys" asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
