@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="mb-4">Admin Dashboard</h2>

<p class="text-muted mb-4">Manage store operations from this area.</p>

<div class="d-flex flex-wrap gap-2">
    <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn btn-primary">Manage Orders</a>
    <a asp-area="Admin" asp-controller="Courses" asp-action="Enrollments" class="btn btn-primary">View Course Enrollments</a>
    <a asp-area="Admin" asp-controller="Toys" asp-action="Create" class="btn btn-outline-primary">Add Toy</a>
    <a asp-area="" asp-controller="Toys" asp-action="Index" class="btn btn-secondary">Back to Public Catalog</a>
</div>
