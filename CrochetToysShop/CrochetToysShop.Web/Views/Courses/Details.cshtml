@model CrochetToysShop.Web.ViewModels.Courses.CourseDetailsViewModel

@{
    ViewData["Title"] = @Model.Name;
}

<h2 class="mb-4">@Model.Name</h2>
<p class="text-muted mb-4">This is an enrollment-based learning course. Reserve your spot to join the training group.</p>

<div class="row g-4 mb-5">
    <div class="col-md-6">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" asp-append-version="true" alt="@Model.Name" class="img-fluid rounded border" style="width: 100%; object-fit: contain; background-color: #f8f9fa;" />
        }
        else
        {
            <img src="/images/toys/no-image.svg" asp-append-version="true" alt="@Model.Name" class="img-fluid rounded border" style="width: 100%; object-fit: contain; background-color: #f8f9fa;" />
        }
    </div>

    <div class="col-md-6">
        <dl class="row mt-2">
            <dt class="col-sm-4">Course Fee</dt>
            <dd class="col-sm-8 fw-bold fs-5">@Model.Price.ToEuro()</dd>

            <dt class="col-sm-4">Duration</dt>
            <dd class="col-sm-8">@Model.DurationHours hours</dd>

            <dt class="col-sm-4">Difficulty</dt>
            <dd class="col-sm-8">@Model.Difficulty</dd>

            <dt class="col-sm-4">Enrolled</dt>
            <dd class="col-sm-8">@Model.EnrolledCount / @Model.MaxStudents</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">
                @if (Model.CanEnroll)
                {
                    <span class="badge bg-success">Available</span>
                }
                else
                {
                    <span class="badge bg-danger">Full</span>
                }
            </dd>
        </dl>

        <hr />

        <p class="text-muted">@Model.Description</p>
        <p class="small text-muted mb-0">Enrollment is available for authenticated users in the <strong>User</strong> role. Course status is based on remaining spots.</p>

        <div class="course-actions">
            <a asp-action="Index" class="btn btn-secondary course-action-btn">Back to Courses</a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                @if (User.IsInRole(Roles.Admin))
                {
                    <span class="small text-muted">Admin view - enrollment disabled.</span>
                }
                else if (User.IsInRole(Roles.User))
                {
                    @if (Model.IsUserEnrolled)
                    {
                        <button type="button" class="btn btn-success course-action-btn" disabled>Already Enrolled</button>
                    }
                    else if (Model.CanEnroll)
                    {
                        <form asp-action="Enroll" asp-route-id="@Model.Id" method="post" class="m-0">
                            <button type="submit" class="btn btn-primary course-action-btn">Enroll in This Course</button>
                        </form>
                    }
                    else
                    {
                        <button type="button" class="btn btn-danger course-action-btn" disabled>Course Full</button>
                    }
                }
            }
            else
            {
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-warning course-action-btn">Log In to Enroll</a>
            }
        </div>
    </div>
</div>
