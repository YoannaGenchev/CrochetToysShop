@model CrochetToysShop.Web.ViewModels.Courses.CourseIndexViewModel

@{
    ViewData["Title"] = "Crochet Courses";
}

<h2 class="mb-4">@ViewData["Title"]</h2>
<p class="text-muted mb-4">Join guided crochet lessons. Each course card shows the course fee, level, duration, and current enrollment capacity so you can decide where to enroll.</p>

<form method="get" asp-action="Index" class="mb-4">
    <div class="row g-2">
        <div class="col-md-4">
            <select name="difficulty" class="form-select">
                <option value="">All Difficulty Levels</option>
                @foreach (var difficulty in Model.AvailableDifficulties)
                {
                    <option value="@difficulty" selected="@(Model.DifficultyFilter == difficulty)">@difficulty</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
        </div>
    </div>
</form>

@if (!Model.Courses.Any())
{
    <div class="alert alert-info">No courses available.</div>
}
else
{
    <div class="row g-4 courses-grid">
        @foreach (var course in Model.Courses)
        {
            <div class="col-md-4 d-flex">
                <div class="card h-100 course-card">
                    @if (!string.IsNullOrWhiteSpace(course.ImageUrl))
                    {
                        <img class="card-img-top toy-card-img course-card-img" src="@course.ImageUrl" asp-append-version="true" alt="@course.Name" loading="lazy" decoding="async" />
                    }
                    else
                    {
                        <img class="card-img-top toy-card-img course-card-img course-card-img--fallback" src="/images/toys/no-image.svg" asp-append-version="true" alt="@course.Name" loading="lazy" decoding="async" />
                    }

                    <div class="card-body course-card-body">
                        <h5 class="card-title course-card-title">@course.Name</h5>
                        <p class="card-text course-card-meta">
                            <small><strong>Duration:</strong> @course.DurationHours hours • <strong>Level:</strong> @course.Difficulty</small>
                        </p>
                        <p class="card-text course-card-description">Includes full course description, requirements, and enrollment action on the details page.</p>
                        <p class="card-text fw-bold course-card-fee">Course fee: @course.Price.ToEuro()</p>
                        <p class="card-text course-card-enrollment">
                            <small><strong>Enrollment:</strong> @course.EnrolledCount / @course.MaxStudents spots taken</small>
                        </p>
                    </div>
                    <div class="card-footer bg-white border-0 course-card-footer">
                        <a asp-action="Details" asp-route-id="@course.Id" class="btn w-100 course-card-btn">View & Enroll</a>
                    </div>
                </div>
       </div>
}

@if (Model.Pagination.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-center">
            @if (Model.Pagination.HasPreviousPage)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-difficulty="@Model.DifficultyFilter" asp-route-page="1">First</a>
                </li>
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-difficulty="@Model.DifficultyFilter" asp-route-page="@(Model.Pagination.CurrentPage - 1)">Previous</a>
                </li>
            }

            @foreach (var pageNumber in Model.Pagination.PageNumbers)
            {
                <li class="page-item @(pageNumber == Model.Pagination.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-difficulty="@Model.DifficultyFilter" asp-route-page="@pageNumber">@pageNumber</a>
                </li>
            }

            @if (Model.Pagination.HasNextPage)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-difficulty="@Model.DifficultyFilter" asp-route-page="@(Model.Pagination.CurrentPage + 1)">Next</a>
                </li>
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-difficulty="@Model.DifficultyFilter" asp-route-page="@Model.Pagination.TotalPages">Last</a>
                </li>
            }
        </ul>
    </nav>
    <div class="text-center text-muted mt-2">
        <small>Page @Model.Pagination.CurrentPage of @Model.Pagination.TotalPages (Total: @Model.Pagination.TotalCount items)</small>
    </div>
}
    </div>
}
