@{
    ViewData["Title"] = "Server Error";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="text-center">
                <h1 class="display-1 fw-bold text-danger">500</h1>
                <h2 class="mb-4">Internal Server Error</h2>
                <p class="lead mb-4">
                    Oops! Something went wrong on our end.
                </p>

                <div class="alert alert-danger" role="alert">
                    <strong>We're sorry!</strong> An unexpected error occurred while processing your request.
                    Our team has been notified and is working to fix the issue.
                </div>

                <p class="text-muted mb-4">
                    Error Code: 500
                </p>

                <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-4 gap-3">
                        Go Back Home
                    </a>
                    <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg px-4">
                        Go Back
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
