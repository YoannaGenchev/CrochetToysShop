@{
    ViewData["Title"] = "Home";
}

<section class="hero-section">
    <div class="hero-content">
        <h1>Handmade Crochet Toys for Cozy Moments</h1>
        <p class="lead">Discover soft, lovingly crafted toys made to bring comfort, imagination, and joy to every little adventure.</p>

        <div class="hero-actions d-flex flex-column flex-sm-row justify-content-center gap-2 mt-4">
            <a asp-controller="Toys" asp-action="Index" class="btn btn-hero">Browse Toys</a>
            @if (User?.Identity?.IsAuthenticated != true)
            {
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-hero btn-hero-secondary">Register</a>
            }
        </div>
    </div>
</section>
