@model CrochetToysShop.Web.ViewModels.Toys.ToyDetailsViewModel

@{
    ViewData["Title"] = "Details";
}

<h2 class="page-title mb-4">@Model.Name</h2>

<div class="row g-4 mb-5 toy-details-section">
    <div class="col-md-6">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" asp-append-version="true" alt="@Model.Name" class="img-fluid rounded border toy-details-image" />
        }
        else
        {
            <img src="/images/toys/no-image.svg" asp-append-version="true" alt="@Model.Name" class="img-fluid rounded border toy-details-image" />
        }
    </div>

    <div class="col-md-6">
        <dl class="row mt-2">
            <dt class="col-sm-4">Category</dt>
            <dd class="col-sm-8"><span class="badge bg-secondary">@Model.CategoryName</span></dd>

            <dt class="col-sm-4">Price</dt>
            <dd class="col-sm-8 fw-bold fs-5">@Model.Price.ToEuro()</dd>

            <dt class="col-sm-4">Size</dt>
            <dd class="col-sm-8">@Model.SizeCm cm</dd>

            <dt class="col-sm-4">Difficulty</dt>
            <dd class="col-sm-8">@Model.Difficulty</dd>

            <dt class="col-sm-4">Availability</dt>
            <dd class="col-sm-8">
                @if (Model.IsAvailable)
                {
                    <span class="badge bg-success">Available</span>
                }
                else
                {
                    <span class="badge bg-danger">Out of stock</span>
                }
            </dd>
        </dl>

        <hr />

        <p class="text-muted">@Model.Description</p>

        <div class="mt-4 d-flex flex-wrap gap-2 toy-details-actions">
            <a asp-action="Index" class="btn btn-secondary">Back</a>
            @if (Model.IsAvailable)
            {
                <a asp-action="Order" asp-route-id="@Model.Id" class="btn btn-success">Order</a>
            }
            @if (User.IsInRole(Roles.Admin))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
            }
        </div>
    </div>
</div>
