@model CrochetToysShop.Web.ViewModels.Orders.OrderCreateViewModel

@{
    ViewData["Title"] = $"Order Request - {Model.ToyName ?? "Selected Toy"}";
}

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<h2 class="mb-2">Order Request: @Model.ToyName</h2>
<p class="text-muted mb-4">Submit this form to request the selected handmade toy. This shop currently processes one toy per request.</p>

<form asp-action="Order" method="post">
    <input type="hidden" asp-for="ToyId" />

    <div class="mb-3">
        <label asp-for="CustomerName" class="form-label"></label>
        <input asp-for="CustomerName" class="form-control" />
        <span asp-validation-for="CustomerName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PhoneNumber" class="form-label"></label>
        <input asp-for="PhoneNumber" class="form-control" />
        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Address" class="form-label"></label>
        <textarea asp-for="Address" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Address" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Submit Order Request</button>
    <a asp-action="Details" asp-route-id="@Model.ToyId" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
