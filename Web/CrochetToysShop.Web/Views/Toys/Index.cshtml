@model CrochetToysShop.Web.ViewModels.Toys.ToyIndexViewModel

@{
    ViewData["Title"] = "Toys";
}

<h2 class="mb-4">@ViewData["Title"]</h2>

@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-primary mb-3">+ Add toy</a>
}

<form method="get" asp-action="Index" class="mb-4">
    <div class="row g-2">
        <div class="col-md-4">
            <select asp-for="CategoryId" class="form-select">
                <option value="">All categories</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category.Id" selected="@(Model.CategoryId == category.Id)">@category.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
        </div>
    </div>
</form>

@if (!Model.Toys.Any())
{
    <div class="alert alert-info">No toys yet.</div>
}
else
{
    <div class="row">
        @foreach (var toy in Model.Toys)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    @if (!string.IsNullOrWhiteSpace(toy.ImageUrl))
                    {
                        <img class="card-img-top toy-card-img" src="@toy.ImageUrl" asp-append-version="true" alt="@toy.Name" />
                    }
                    else
                    {
                        <img class="card-img-top toy-card-img" src="/images/toys/no-image.svg" asp-append-version="true" alt="@toy.Name" />
                    }

                    <div class="card-body">
                        <h5 class="card-title">@toy.Name</h5>
                        <p class="card-text"><span class="badge bg-secondary">@toy.CategoryName</span></p>
                        <span class="badge @(toy.IsAvailable ? "bg-success" : "bg-danger")">@(toy.IsAvailable ? ApplicationConstants.UILabels.Available : ApplicationConstants.UILabels.OutOfStock)</span>
                        <p class="card-text fw-bold">@toy.Price.ToEuro()</p>
                    </div>
                    <div class="card-footer bg-white border-0">
                        <a asp-controller="Toys" asp-action="Details" asp-route-id="@toy.Id" class="btn btn-outline-primary w-100">Details</a>

                        @if (User.IsInRole("Admin"))
                        {
                            <div class="mt-2 d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@toy.Id" class="btn btn-warning w-50">Edit</a>
                                <a asp-action="Delete" asp-route-id="@toy.Id" class="btn btn-danger w-50">Delete</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
